# ===== Rockstar Social Club 登录态 =====
# 从浏览器登录 socialclub.rockstargames.com 后，F12 -> Network -> 任一请求
# -> Request Headers -> Cookie 整段复制到这里（含 BearerToken / RMT 等）。
# 注意：这是敏感凭证，不要提交到 git，不要分享。
RSC_COOKIE=""

# 可选：部分接口需要 X-Requested-With / RequestVerificationToken，抓到后填这里
RSC_REQUEST_VERIFICATION_TOKEN=""

# ===== 采集配置 =====
# 数据有效期（秒），命中则直接返回缓存，默认 2 小时（对齐空桑）
CACHE_TTL_SECONDS=7200
# 单次请求超时（秒）
HTTP_TIMEOUT=20
# 采集失败重试次数
HTTP_RETRIES=2
# 可选：出海代理，如 http://127.0.0.1:7890 ；留空则直连
HTTP_PROXY=""

# ===== 限速（对齐空桑）=====
# 新数据申请：每个昵称每小时最多次数
POST_RATE_PER_HOUR=10
# 普通查询：每 IP 每 10 分钟最多次数
QUERY_RATE_PER_10MIN=60

# ===== 存储 =====
DB_PATH="socialclub.db"
